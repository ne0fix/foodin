// Verificar login do cliente (uma vez ao montar)
const [clienteNome, setClienteNome] = useState<string | null>(null);

useEffect(() => {
  fetch('/api/cliente/me')
    .then(r => r.ok ? r.json() : null)
    .then(d => d?.nome ? setClienteNome(d.nome.split(' ')[0]) : null)
    .catch(() => {});
}, []);

// Ícone de conta muda conforme estado:
// Não logado → href="/cliente/login" | ícone User
// Logado → href="/cliente" | ícone User + "Olá, {nome}"
```

