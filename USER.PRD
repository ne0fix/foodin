  pedidos/
    route.ts                  GET — listar pedidos do cliente
    [id]/route.ts             GET — detalhe do pedido
```

**Estrutura padrão de Route Handler protegido:**
```typescript
import { NextRequest, NextResponse } from 'next/server';
import { getClienteFromNextRequest } from '@/src/lib/clienteAuth';
import { prisma } from '@/src/lib/prisma';

export async function GET(req: NextRequest) {
  const cliente = await getClienteFromNextRequest(req);
  if (!cliente) {
    return NextResponse.json({ error: 'Não autorizado' }, { status: 401 });
  }

  // ... lógica
}
```

